# ── REQUIRED ──────────────────────────────────────────────
SECRET_KEY=change_me_in_production
JWT_SECRET_KEY=change_jwt_in_production
MONGO_URI=mongodb://localhost:27017/campuslostfound
REDIS_URL=redis://localhost:6379/0

# ── AI ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_from_aistudio.google.com

# ── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Optional ──────────────────────────────────────────────
DEBUG=False
FLASK_ENV=production
PORT=5000
ALLOWED_ORIGINS=http://localhost:5173
MODEL_PATH=models/categorization_model.h5
CLASSES_PATH=models/classes.txt
